# ============================================================
# WohnungsRadar Backend – Umgebungsvariablen
# ============================================================
# Diese Datei als ".env" kopieren und die Werte eintragen:
#   cp .env.example .env
#
# Die .env-Datei wird NICHT ins Git-Repository eingecheckt!
# ============================================================

# Server-Port (Standard: 3001)
PORT=3001

# URL des Frontends (für CORS-Freigabe)
# Lokal: http://localhost:5173
# Render: https://wohnungsradar.onrender.com
FRONTEND_URL=http://localhost:5173

# ── Supabase ────────────────────────────────────────────────
# Supabase Dashboard → Settings → API

# Projekt-URL (z.B. https://kqgzugyfaagxlzyginsk.supabase.co)
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co

# Anon Key (öffentlich, für Lese-Anfragen)
SUPABASE_ANON_KEY=eyJ...

# Service Role Key (GEHEIM! Nur im Backend, niemals ans Frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
