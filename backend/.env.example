# ============================================================
# WohnungsRadar Backend – Umgebungsvariablen
# ============================================================
# Diese Datei als ".env" kopieren und die Werte eintragen:
#   cp .env.example .env
#
# Die .env-Datei wird NICHT ins Git-Repository eingecheckt!
# ============================================================

# Server-Port (Standard: 3001)
PORT=3001

# URL des Frontends (für CORS-Freigabe)
# Lokal: http://localhost:5173
# Render: https://wohnungsradar.onrender.com
FRONTEND_URL=http://localhost:5173

# ── Supabase ────────────────────────────────────────────────
# Supabase Dashboard → Settings → API

# Projekt-URL (z.B. https://kqgzugyfaagxlzyginsk.supabase.co)
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co

# Anon Key (öffentlich, für Lese-Anfragen)
SUPABASE_ANON_KEY=eyJ...

# Service Role Key (GEHEIM! Nur im Backend, niemals ans Frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── E-Mail (SMTP) ────────────────────────────────────────────
# Für E-Mail-Benachrichtigungen bei neuen Inseraten.
# Ohne diese Angaben werden E-Mails nur in der Konsole geloggt (kein Fehler).
#
# Beispiel Gmail (App-Passwort benötigt → Google-Konto → Sicherheit → App-Passwörter):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=deine-adresse@gmail.com
#   SMTP_PASS=dein-app-passwort
#
# Beispiel Infomaniak:
#   SMTP_HOST=mail.infomaniak.com
#   SMTP_PORT=587

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine-adresse@example.com
SMTP_PASS=dein-passwort
SMTP_FROM=WohnungsRadar <deine-adresse@example.com>

# ── Resend (Alternative zu SMTP, für Supabase Edge Functions) ──
# Konto erstellen auf https://resend.com (kostenlos: 3000 E-Mails/Monat)
# Hinweis: Bei Edge Functions als Supabase Secret setzen:
#   supabase secrets set RESEND_API_KEY=re_...
RESEND_API_KEY=re_...
RESEND_FROM=WohnungsRadar <noreply@deinedomain.ch>

# ── Scraper-Optionen ─────────────────────────────────────────
# true = automatischen Scraper-Scheduler beim Start deaktivieren
# (nützlich für lokale Entwicklung ohne regelmässige Hintergrundaufgaben)
DISABLE_SCHEDULER=false
